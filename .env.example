# 環境変数の見本（実値は .env.local / Vercel の環境変数に設定する）
DATABASE_URL=postgres://user:password@host:5432/dbname
ANTHROPIC_API_KEY=
SLACK_WEBHOOK_URL=
BLOB_READ_WRITE_TOKEN=
GMAIL_USER=
GMAIL_APP_PASSWORD=
GMAIL_INTAKE_ALIAS=
APP_BASE_URL=http://localhost:3000

# Clerk（未設定なら担当者コード＋Cookie方式のフォールバックで動く）
# ユーザーの publicMetadata に { "operatorCode": "op01", "role": "admin" } を設定すると
# 担当者コードとロール（admin/operator）が反映される。
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Vercel Cron 用の保護トークン（/api/cron/mail-intake の認可に使用）
CRON_SECRET=
